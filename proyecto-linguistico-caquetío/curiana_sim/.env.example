# CURIANA — Variables de entorno
# Copia a .env y rellena los valores reales
# ══════════════════════════════════════════════

# Anthropic (obligatorio)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (opcional — sin esto la simulación corre en modo local JSON)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# LangSmith (opcional — activa tracing automático)
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=curiana
